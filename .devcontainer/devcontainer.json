{
  "name": "fsferrara/machines",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "REMOTE_USER": "fsferrara"
    }
  },
  "remoteUser": "fsferrara",
  "containerEnv": {
    "GIT_USER": "fsferrara"
  },
  "features": {
    "../dotfiles": {},
    "../features/git": {}
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/fsferrara/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/home/fsferrara/workspace"
}
