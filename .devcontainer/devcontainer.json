{
  "name": "fsferrara/machines",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "REMOTE_USER": "user"
    }
  },
  "remoteUser": "user",
  "containerEnv": {
    "GIT_USER": "user"
  },
  "features": {
    "./dotfiles": {},
    "./features/git": {},
    "./features/ssh": {},
    "./features/zsh": {},
    "./features/tmux": {},
    "./features/gh": {},
    "./features/vim": {},
    "./private": {}
  },
  "overrideFeatureInstallOrder": [
    "my-feature-dotfiles",
    "my-feature-git",
    "my-feature-ssh",
    "my-feature-zsh",
    "my-feature-tmux",
    "my-feature-gh",
    "my-feature-vim",
    "my-feature-secrets"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/user/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/home/user/workspace",
  "mounts": [
    "source=devcontainer-home,target=/home/user,type=volume"
  ],
  "postStartCommand": "echo '[devcontainer] user: user'",
  "waitFor": "postStartCommand"
}
