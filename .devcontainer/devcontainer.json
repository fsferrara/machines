{
  "name": "fsferrara/machines",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "REMOTE_USER": "user"
    }
  },
  "remoteUser": "user",
  "containerEnv": {
    "GIT_USER": "user"
  },
  "features": {
    "./dotfiles": {},
    "./features/git": {},
    "./features/ssh": {},
    "./features/zsh": {},
    "./features/node": {},
    "./features/python": {},
    "./features/tmux": {},
    "./features/gh": {},
    "./features/vim": {},
    "./features/lazyvim": {},
    "./features/aws": {},
    "./features/serena": {},
    "./features/claude-code": {},
    "./features/swiftly": {},
    "./private": {}
  },
  "overrideFeatureInstallOrder": [
    "./dotfiles",
    "./features/git",
    "./features/ssh",
    "./features/zsh",
    "./features/node",
    "./features/python",
    "./features/tmux",
    "./features/gh",
    "./features/vim",
    "./features/lazyvim",
    "./features/aws",
    "./features/serena",
    "./features/claude-code",
    "./features/swiftly",
    "./private"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/user/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/home/user/workspace",
  "mounts": [
    "source=devcontainer-home,target=/home/user,type=volume",
    "source=${localEnv:HOME}/github,target=/home/user/github,type=bind,consistency=delegated",
    "source=${localEnv:HOME}/work,target=/home/user/work,type=bind,consistency=delegated",
    "source=${localEnv:HOME}/tools,target=/home/user/tools,type=bind,consistency=delegated",
    "source=${localEnv:HOME}/.aws,target=/home/user/.aws,type=bind,consistency=delegated",
    "source=${localEnv:HOME}/.claude,target=/home/user/.claude,type=bind,consistency=delegated"
  ],
  "postStartCommand": "echo '[devcontainer] user/password'",
  "waitFor": "postStartCommand"
}
