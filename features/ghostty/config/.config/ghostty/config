# Font Settings (ensure these fonts are installed on your system)
font-family = "MesloLGM Nerd Font Mono"
font-size = 14

# Theme
theme = TokyoNight Storm

# Window Settings
window-theme = dark
window-show-tab-bar = always
window-new-tab-position = current
window-subtitle = working-directory

# Scrolling and Selection
scrollbar = never
scrollback-limit = 10000

# macOS Specific Tweaks (ignored on Linux automatically)
#macos-titlebar-style = "hidden"
macos-option-as-alt = true

# Linux Specific Tweaks (ignored on macOS automatically)
gtk-single-instance = true

# Custom Keybindings
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab

# Mouse
mouse-reporting = true
# press SHIFT to use system mouse capabilities
mouse-shift-capture = false

# Shaders
custom-shader = ~/.config/ghostty/shaders/bloom.glsl

